# OCI 콘솔 → 우측 상단 프로필 → Tenancy: OCID 복사
tenancy_ocid = "ocid1.tenancy.oc1..xxxx"

# OCI 콘솔 → 프로필 → User Settings: OCID 복사
user_ocid = "ocid1.user.oc1..xxxx"

# OCI 콘솔 → User Settings → API Keys → Fingerprint
fingerprint = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"

# OCI API 개인키 경로 (~/.oci/oci_api_key.pem)
private_key_path = "~/.oci/oci_api_key.pem"

# OCI 리전 (춘천: ap-chuncheon-1, 서울: ap-seoul-1)
region = "ap-chuncheon-1"

# OCI 콘솔 → Compartments: OCID 복사 (루트 테넌시와 동일해도 됨)
compartment_ocid = "ocid1.compartment.oc1..xxxx"

# OCI 콘솔 → Compute → Instances → Create Instance → Availability Domain
availability_domain = "IYfK:AP-CHUNCHEON-1-AD-1"

# OCI 콘솔 → Compute → Images → Ubuntu 22.04 ARM 이미지 OCID
instance_image_ocid = "ocid1.image.oc1.ap-chuncheon-1.xxxx"

# SSH 공개키 (cat ~/.ssh/id_rsa.pub)
ssh_public_key = "ssh-rsa AAAA..."

# PostgreSQL getdon 사용자 비밀번호
db_password = "your-secure-password"